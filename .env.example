# Supabase project URL, e.g. https://<project-ref>.supabase.co
VITE_SUPABASE_URL=
# Publishable/anon key (do not use service role key in frontend)
VITE_SUPABASE_ANON_KEY=
# Optional edge base URL, e.g. https://<project-ref>.supabase.co/functions/v1
# If omitted, app derives it from VITE_SUPABASE_URL + /functions/v1
VITE_EDGE_BASE_URL=
# Optional build marker shown in diagnostics panel
VITE_APP_BUILD=
